<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head.ejs') %>
  <title>My Profile | JobFinder</title>
</head>

<body class="bg-gray-50 font-sans">

  <!-- Navbar -->
  <%- include('partials/navbar.ejs') %>

  <!-- Profile Section -->
  <div class="container mx-auto p-4 md:p-8">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-6 text-center">Your Profile</h1>

    <!-- Profile Header -->
    <div class="bg-white p-6 rounded-xl shadow-lg mb-8 text-center max-w-xl mx-auto">
      <div
        class="w-24 h-24 bg-blue-100 rounded-full mx-auto flex items-center justify-center text-blue-600 text-4xl mb-3 border-2 border-blue-500">
        <i class="fas fa-user"></i>
      </div>
      <h3 class="text-2xl font-semibold text-gray-800"><%= user.name %></h3>
      <p class="text-md text-gray-500 mb-2"><%= user.email %></p>
      <span
        class="inline-block bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-sm font-semibold capitalize">
        <%= user.role %>
      </span>
    </div>

    <!-- Edit Form -->
    <main class="bg-white p-6 rounded-xl shadow-lg max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-800 border-b pb-3 mb-6">Account Details</h2>

      <% if (typeof message !== 'undefined' && message) { %>
      <div class="mb-4 bg-green-100 text-green-700 p-3 rounded-md border border-green-300">
        <%= message %>
      </div>
      <% } %>

      <form action="/users/profile" method="POST" class="space-y-6">

        <!-- Name and Email -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="name" class="block text-sm font-medium text-gray-700">Full Name</label>
            <input type="text" name="name" id="name" value="<%= user.name %>"
              class="w-full p-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
          </div>

          <div class="space-y-2">
            <label for="email" class="block text-sm font-medium text-gray-700">Email Address</label>
            <input type="email" id="email" value="<%= user.email %>" disabled
              class="w-full p-3 border border-gray-300 bg-gray-100 rounded-lg">
          </div>
        </div>

        <!-- Contact -->
        <div class="space-y-2">
          <label for="contact" class="block text-sm font-medium text-gray-700">Contact Number</label>
          <input type="text" name="contact" id="contact" value="<%= user.contact || '' %>"
            placeholder="Enter your contact number"
            class="w-full p-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
        </div>


        <!-- Skills -->
        <div class="space-y-2">
          <label for="skills" class="block text-sm font-medium text-gray-700">Skills</label>
          <input type="text" name="skills" id="skills" value="<%= user.skills ? user.skills.join(', ') : '' %>"
            placeholder="e.g. Python, Node.js, MongoDB"
            class="w-full p-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
          <p class="text-sm text-gray-400">Separate multiple skills with commas.</p>
        </div>

        <!-- Save Button -->
        <div class="pt-4 border-t border-gray-100">
          <button type="submit"
            class="px-6 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition">
            Save Changes
          </button>
        </div>
      </form>
    </main>
  </div>

  <%- include('partials/footer.ejs') %>
</body>
</html>
