
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head.ejs') %>
  <title>Applicants | <%= job.title %></title>
</head>
<body class="bg-gray-50 font-sans">
  <%- include('partials/navbar.ejs') %>

  <div class="container mx-auto p-6">
    <h1 class="text-3xl font-bold text-gray-800 mb-6">
      Applicants for "<%= job.title %>"
    </h1>

    <% if (applications.length === 0) { %>
      <p class="text-gray-600 text-lg">No one has applied for this job yet.</p>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full bg-white border border-gray-200 rounded-lg shadow-md">
          <thead class="bg-blue-600 text-white">
            <tr>
              <th class="py-3 px-4 text-left">Applicant Name</th>
              <th class="py-3 px-4 text-left">Email</th>
              <th class="py-3 px-4 text-left">Skills</th>
              <th class="py-3 px-4 text-left">Contact</th>
            </tr>
          </thead>
          <tbody>
            <% applications.forEach(app => { %>
              <tr class="border-t hover:bg-gray-50 transition">
                <td class="py-3 px-4"><%= app.user.name %></td>
                <td class="py-3 px-4"><%= app.user.email %></td>
                <td class="py-3 px-4">
                  <% if (app.user.skills && app.user.skills.length > 0) { %>
                    <%= app.user.skills.join(", ") %>
                  <% } else { %>
                    <span class="text-gray-400">Not Provided</span>
                  <% } %>
                </td>
                <td class="py-3 px-4"><%= app.user.contact || "N/A" %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <%- include('partials/footer.ejs') %>
</body>
</html>
