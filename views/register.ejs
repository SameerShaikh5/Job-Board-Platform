<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>JobFinder | Sign Up</title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Font Awesome for icons -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
  />
</head>
<body
  class="bg-gray-50 font-sans min-h-screen flex items-center justify-center p-4"
>
  <!-- Signup Card Container -->
  <div class="bg-white p-8 md:p-10 rounded-xl shadow-2xl w-full max-w-md text-center">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-blue-600 mb-2">JOBFINDER</h1>
      <h2 class="text-2xl font-semibold text-gray-800">Create Your Account</h2>
    </header>

    <!-- Error Message -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-4 bg-red-100 text-red-600 p-3 rounded-md border border-red-300">
                <%= error %>
            </div>
        <% } %>

    <!-- Register Form -->
    <form action="/users/register" method="POST" class="space-y-6">

      <!-- Full Name -->
      <div
        class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500"
      >
        <i class="fas fa-user text-gray-400"></i>
        <input
          type="text"
          name="name"
          placeholder="Full Name"
          required
          class="w-full focus:outline-none text-gray-700"
        />
      </div>

      <!-- Email -->
      <div
        class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500"
      >
        <i class="fas fa-envelope text-gray-400"></i>
        <input
          type="email"
          name="email"
          placeholder="Email Address"
          required
          class="w-full focus:outline-none text-gray-700"
        />
      </div>

      <!-- Contact Number -->
      <div
        class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500"
      >
        <i class="fas fa-phone text-gray-400"></i>
        <input
          type="number"
          name="contact"
          placeholder="Contact Number"
          minlength="10"
          maxlength="10"
          required
          class="w-full focus:outline-none text-gray-700"
        />
      </div>

      <!-- Role (Select Option) -->
      <div
        class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500"
      >
        <i class="fas fa-user-tag text-gray-400"></i>
        <select
          name="role"
          required
          class="w-full bg-transparent focus:outline-none text-gray-700"
        >
          <option value="">Select Role</option>
          <option value="user">User</option>
          <option value="employer">Employer</option>
        </select>
      </div>

      <!-- Skills Input -->
      <div
        class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500"
      >
        <i class="fas fa-code text-gray-400"></i>
        <input
          type="text"
          name="skills"
          placeholder="Enter skills (comma-separated)"
          required
          class="w-full focus:outline-none text-gray-700"
        />
      </div>

      <!-- Password -->
      <div
        class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500"
      >
        <i class="fas fa-lock text-gray-400"></i>
        <input
          type="password"
          name="password"
          placeholder="Password"
          minlength="6"
          maxlength="30"
          required
          class="w-full focus:outline-none text-gray-700"
        />
      </div>

      <!-- Submit Button -->
      <button
        type="submit"
        class="w-full py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
      >
        Sign Up
      </button>
    </form>

    <!-- Divider -->
    <div class="my-6 flex items-center">
      <div class="flex-grow border-t border-gray-200"></div>
      <span class="mx-4 text-sm text-gray-400">OR</span>
      <div class="flex-grow border-t border-gray-200"></div>
    </div>

    <!-- Footer -->
    <footer class="mt-8 text-sm text-gray-600">
      Already have an account?
      <a href="/users/login" class="text-blue-600 font-semibold hover:text-blue-800"
        >Login</a
      >
    </footer>
  </div>
</body>
</html>
