<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head.ejs') %>
        <title>
            <%= job.title %> | JobFinder
        </title>
</head>

<body class="bg-gray-50 font-sans">

    <%- include('partials/navbar.ejs')%>

        <!-- Main Content Area -->
        <div class="container mx-auto p-4 md:p-8 pb-20 lg:pb-8">
            <% if (errorMessage) { %>
                <div class="bg-red-100 text-red-700 p-3 rounded-lg mb-4 border border-red-300">
                    <%= errorMessage %>
                </div>
                <% } %>

                    <% if (successMessage) { %>
                        <div class="bg-green-100 text-green-700 p-3 rounded-lg mb-4 border border-green-300">
                            <%= successMessage %>
                        </div>
                        <% } %>


                            <!-- Job Header Section -->
                            <div class="bg-white p-6 rounded-xl shadow-lg mb-8 border-t-4 border-blue-600">
                                <div class="flex items-center space-x-4 mb-4">
                                    <!-- Company Logo Placeholder -->
                                    <div
                                        class="w-16 h-16 bg-gray-200 rounded-lg flex items-center justify-center text-gray-600 text-xl font-bold">
                                        <%= job.company.charAt(0) %>
                                    </div>
                                    <div>
                                        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-800">
                                            <%= job.title %>
                                        </h1>
                                        <p class="text-lg text-gray-500">
                                            <%= job.company %>
                                        </p>
                                    </div>
                                </div>

                                <div
                                    class="flex flex-col md:flex-row md:items-center md:justify-between space-y-4 md:space-y-0 pt-4 border-t border-gray-100">
                                    <!-- Quick Facts -->
                                    <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-600">
                                        <div class="flex items-center space-x-1">
                                            <i class="fas fa-map-marker-alt text-blue-500"></i>
                                            <span>
                                                <%= job.location %>
                                            </span>
                                        </div>

                                    </div>

                                    <!-- Apply Button (Visible on Desktop/Tablet) -->
                                    <% if (user && user.role==="user" && !hasApplied) { %>
                                        <a href="/jobs/apply/<%= job._id %>"
                                            class="hidden md:block px-8 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition w-full md:w-auto">
                                            Apply Now
                                        </a>
                                        <% } else if (user && user.role==="user" && hasApplied) { %>
                                            <button disabled
                                                class="hidden md:block px-8 py-3 bg-gray-400 text-white font-semibold rounded-lg cursor-not-allowed w-full md:w-auto">
                                                Already Applied
                                            </button>
                                            <% } %>

                                </div>
                            </div>

                            <!-- Job Details and Quick Facts (Responsive Grid) -->
                            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

                                <!-- Column 1: Job Description -->
                                <div class="lg:col-span-2 space-y-6">
                                    <section class="bg-white p-6 rounded-xl shadow-lg">
                                        <h2 class="text-2xl font-bold text-gray-800 mb-4 border-b pb-2">Job Summary</h2>
                                        <p class="text-gray-700 leading-relaxed">
                                            <%= job.description %>
                                        </p>
                                    </section>

                                    <section class="bg-white p-6 rounded-xl shadow-lg">
                                        <h2 class="text-2xl font-bold text-gray-800 mb-4 border-b pb-2">Required Skills
                                            & Experience</h2>
                                        <ul class="list-disc list-inside space-y-3 text-gray-700 leading-relaxed pl-4">
                                            <% job.skillsRequired.forEach(skill=> { %>
                                                <li>
                                                    <%= skill %>
                                                </li>
                                                <% }) %>
                                        </ul>
                                    </section>

                                    <!-- Edit/Delete Buttons -->
                                    <% if (user && user.role==="employer" &&
                                        job.postedBy._id.toString()===user._id.toString()) { %>
                                        <div class="flex space-x-4 mt-4">
                                            <a href="/jobs/edit/<%= job._id %>"
                                                class="px-4 py-2 bg-yellow-500 text-white rounded hover:bg-yellow-600 transition">
                                                Edit Job
                                            </a>
                                            <form action="/jobs/delete/<%= job._id %>" method="POST"
                                                onsubmit="return confirm('Are you sure you want to delete this job?');">
                                                <button type="submit"
                                                    class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition">
                                                    Delete Job
                                                </button>
                                            </form>
                                        </div>
                                        <% } %>

                                </div>


                            </div>

        </div>

        <!-- Sticky Mobile Apply Button -->
        <% if (user && user.role==="user" && !hasApplied) { %>
            <div class="fixed bottom-0 left-0 right-0 p-4 bg-white shadow-2xl md:hidden">
                <a href="/jobs/apply/<%= job._id %>"
                    class="w-full py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition block text-center">
                    Apply Now
                </a>
            </div>
            <% } else if (user && user.role==="user" && hasApplied) { %>
                <div class="fixed bottom-0 left-0 right-0 p-4 bg-white shadow-2xl md:hidden">
                    <button disabled
                        class="w-full py-3 bg-gray-400 text-white font-semibold rounded-lg cursor-not-allowed">
                        Already Applied
                    </button>
                </div>
                <% } %>


                    <%- include('partials/footer.ejs') %>
</body>

</html>