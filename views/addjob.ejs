<!DOCTYPE html>
<html lang="en">
<head>
 <%- include('partials/head.ejs') %>
 <title>Add Job | Post a Job</title>
</head>
<body class="bg-gray-50 font-sans min-h-screen flex items-center justify-center p-4">
  <div class="bg-white p-8 md:p-10 rounded-xl shadow-2xl w-full max-w-md text-center">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-blue-600 mb-2">JOBFINDER</h1>
      <h2 class="text-2xl font-semibold text-gray-800">Post a New Job</h2>
    </header>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-4 bg-red-100 text-red-600 p-3 rounded-md border border-red-300">
        <%= error %>
      </div>
    <% } %>

    <form action="/jobs/add" method="POST" class="space-y-6">

      <!-- Job Title -->
      <div class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500">
        <i class="fas fa-briefcase text-gray-400"></i>
        <input
          type="text"
          name="title"
          placeholder="Job Title"
          required
          class="w-full focus:outline-none text-gray-700"
        />
      </div>

      <!-- Company Name -->
      <div class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500">
        <i class="fas fa-building text-gray-400"></i>
        <input
          type="text"
          name="company"
          placeholder="Company Name"
          required
          class="w-full focus:outline-none text-gray-700"
        />
      </div>

      <!-- Location -->
      <div class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500">
        <i class="fas fa-map-marker-alt text-gray-400"></i>
        <input
          type="text"
          name="location"
          placeholder="Location (e.g., Mumbai, Remote)"
          required
          class="w-full focus:outline-none text-gray-700"
        />
      </div>

      <!-- Skills Required -->
      <div class="flex items-center space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500">
        <i class="fas fa-code text-gray-400"></i>
        <input
          type="text"
          name="skillsRequired"
          placeholder="Skills (comma-separated)"
          class="w-full focus:outline-none text-gray-700"
        />
      </div>

      <!-- Description -->
      <div class="flex items-start space-x-3 border border-gray-300 rounded-lg p-3 focus-within:ring-2 focus-within:ring-blue-500">
        <i class="fas fa-align-left text-gray-400 mt-2"></i>
        <textarea
          name="description"
          placeholder="Job Description"
          required
          rows="4"
          class="w-full focus:outline-none text-gray-700 resize-none"
        ></textarea>
      </div>

      <!-- Submit Button -->
      <button
        type="submit"
        class="w-full py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
      >
        Post Job
      </button>
    </form>

    <footer class="mt-8 text-sm text-gray-600">
      <a href="/" class="text-blue-600 font-semibold hover:text-blue-800">
        ← Back to Home
      </a>
    </footer>
  </div>
</body>
</html>
