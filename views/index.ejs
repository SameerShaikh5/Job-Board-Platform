<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head.ejs') %>
        <title>Home | Job Finder</title>
</head>

<body>
    <%- include('partials/navbar.ejs')%>
        <!-- Main Content Area -->
        <div class="container mx-auto p-4 md:p-8">

            <!-- Search Section -->
            <form method="GET" action="/"
                class="flex flex-col md:flex-row bg-white p-4 md:p-6 rounded-xl shadow-lg gap-4">
                <!-- Keywords Input -->
                <div
                    class="flex items-center space-x-3 w-full md:w-2/5 border-b md:border-b-0 md:border-r border-gray-200 pb-3 md:pb-0 md:pr-4">
                    <i class="fas fa-briefcase text-blue-500 text-lg"></i>
                    <input type="text" name="title" placeholder="Job Title, Keyword, or Company"
                        class="w-full focus:outline-none text-gray-700"
                        value="<%= typeof title !== 'undefined' ? title : '' %>">
                </div>

                <!-- Location Input -->
                <div
                    class="flex items-center space-x-3 w-full md:w-2/5 border-b md:border-b-0 md:border-r border-gray-200 pb-3 md:pb-0 md:pr-4">
                    <i class="fas fa-map-marker-alt text-blue-500 text-lg"></i>
                    <input type="text" name="location" placeholder="City, State, or Remote"
                        class="w-full focus:outline-none text-gray-700"
                        value="<%= typeof location !== 'undefined' ? location : '' %>">
                </div>

                <!-- Search Button -->
                <button
                    class="w-full md:w-1/5 bg-blue-600 text-white font-semibold py-3 rounded-lg hover:bg-blue-700 transition">
                    Search
                </button>
            </form>


            <!-- Layout: Filters and Listings (Responsive: Stacks on mobile, sidebar on large screens) -->
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 mt-5">

                <!-- Job Listings Feed (lg:col-span-3) -->
                <main class="lg:col-span-5 space-y-5">

                    <% jobs.forEach(job=> { %>
                        <a href="/jobs/<%= job._id %>" class="block">
                            <div
                                class="job-card bg-white p-5 rounded-xl shadow-lg border-l-4 border-transparent hover:border-blue-500 transition duration-300 cursor-pointer">
                                <div class="flex justify-between items-start">
                                    <div class="flex items-center space-x-4">
                                        <div
                                            class="w-12 h-12 bg-gray-200 rounded-lg flex items-center justify-center text-gray-600 font-bold">
                                            <%= job.company.charAt(0) %>
                                        </div>
                                        <div>
                                            <h3 class="text-xl font-semibold text-gray-800">
                                                <%= job.title %>
                                            </h3>
                                            <p class="text-sm text-gray-500">
                                                <%= job.company %> &middot; <%= job.location %>
                                            </p>
                                        </div>
                                    </div>
                                    <i class="far fa-heart text-gray-400 hover:text-red-500 cursor-pointer text-lg"></i>
                                </div>
                                <p class="text-gray-600 mt-3 mb-4 text-sm">
                                    <%= job.description.substring(0, 100) %>...
                                </p>
                                <div class="flex justify-between items-center border-t pt-3">
                                    <span class="text-xs text-gray-400">Posted <%= job.createdAt.toLocaleDateString() %>
                                    </span>
                                </div>
                            </div>
                        </a>
                        <% }); %>

                </main>

            </div>
        </div>

        <%- include('partials/footer.ejs') %>
</body>

</html>