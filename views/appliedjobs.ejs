<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head.ejs') %>
  <title>Applied Jobs | JobFinder</title>
</head>

<body class="bg-gray-50 font-sans">

  <%- include("partials/navbar.ejs") %>

  <div class="container mx-auto p-4 md:p-8">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-8">Your Applied Jobs</h1>

    <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
      <div class="bg-red-100 text-red-700 p-3 rounded-lg mb-4 border border-red-300">
        <%= errorMessage %>
      </div>
    <% } %>

    <!-- If no jobs -->
    <% if (applications.length === 0) { %>
      <p class="text-gray-600 text-lg">You haven’t applied for any jobs yet.</p>
    <% } else { %>

      <!-- Loop through applications -->
      <div class="space-y-6">
        <% applications.forEach(app => { %>
          <div
            class="bg-white p-5 rounded-xl shadow-lg border-l-4 border-blue-500 flex flex-col md:flex-row justify-between items-start md:items-center">
            
            <!-- Job Details -->
            <div class="mb-4 md:mb-0 md:w-3/5">
              <h2 class="text-xl font-semibold text-gray-800">
                <%= app.job?.title || "Untitled Job" %>
              </h2>
              <p class="text-sm text-gray-500">
                <%= app.job?.company || "Unknown Company" %> &middot;
                <%= app.job?.location || "Location not specified" %>
              </p>

              <div class="mt-3 flex flex-wrap items-center">
                <span
                  class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">
                  <i class="fas fa-check-circle mr-2 text-green-500"></i> Applied
                </span>
                <span class="text-xs text-gray-500 ml-3 mt-1 md:mt-0">
                  on <%= app.createdAt.toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" }) %>
                </span>
              </div>
            </div>

            <!-- View Job Button -->
            <div class="w-full md:w-auto">
              <a href="/jobs/<%= app.job?._id %>"
                class="block w-full md:w-auto bg-blue-600 text-white font-medium px-6 py-2 rounded-lg hover:bg-blue-700 transition text-sm text-center">
                View Job Listing
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <%- include("partials/footer.ejs") %>
</body>

</html>
