<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head.ejs') %>
  <title>Your Posted Jobs | JobFinder</title>
</head>
<body class="bg-gray-50 font-sans">

  <%- include("partials/navbar.ejs") %>

  <div class="container mx-auto p-4 md:p-8">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-8">Your Posted Jobs</h1>

    <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
      <div class="bg-red-100 text-red-700 p-3 rounded-lg mb-4 border border-red-300">
        <%= errorMessage %>
      </div>
    <% } %>

    <% if (jobs.length === 0) { %>
      <p class="text-gray-600 text-lg">You haven’t posted any jobs yet.</p>
    <% } else { %>
      <div class="space-y-6">
        <% jobs.forEach(job => { %>
          <div class="bg-white p-5 rounded-xl shadow-lg border-l-4 border-blue-500 flex flex-col md:flex-row justify-between items-start md:items-center">
            
            <!-- Job Details -->
            <div class="mb-4 md:mb-0 md:w-3/5">
              <h2 class="text-xl font-semibold text-gray-800"><%= job.title %></h2>
              <p class="text-sm text-gray-500"><%= job.company %> &middot; <%= job.location %></p>
              <p class="text-gray-600 mt-2 text-sm"><%= job.description.substring(0, 100) %>...</p>
            </div>

            <!-- Actions -->
            <div class="flex flex-col md:flex-row gap-2">
              <a href="/jobs/<%= job._id %>"
                class="bg-blue-600 text-white font-medium px-4 py-2 rounded-lg hover:bg-blue-700 transition text-sm text-center">
                View
              </a>
              <a href="/jobs/edit/<%= job._id %>"
                class="bg-yellow-500 text-white font-medium px-4 py-2 rounded-lg hover:bg-yellow-600 transition text-sm text-center">
                Edit
              </a>
              <a href="/jobs/<%= job._id %>/applicants"
                class="bg-green-600 text-white font-medium px-4 py-2 rounded-lg hover:bg-green-700 transition text-sm text-center">
                View Applicants
              </a>
              <form action="/jobs/delete/<%= job._id %>?_method=DELETE" method="POST">
                <button type="submit"
                  class="bg-red-600 text-white font-medium px-4 py-2 rounded-lg hover:bg-red-700 transition text-sm text-center">
                  Delete
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <%- include("partials/footer.ejs") %>
</body>
</html>
